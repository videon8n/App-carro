# Chave da API Anthropic (obrigatoria para score de IA)
# Pegue em https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Modelo Claude a usar. Padrao: claude-sonnet-4-6 (bom custo/qualidade)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Porta do servidor
PORT=3000

# Regiao de busca (filtro hard)
REGION_CITY=Campinas
REGION_STATE=SP

# Ano minimo dos carros (inclusive)
MIN_YEAR=2018

# Margem desejada para revenda (usado no prompt da IA)
TARGET_MARGIN=0.15

# Timeout maximo por fonte (ms)
SOURCE_TIMEOUT_MS=45000

# Habilitar Facebook Marketplace (requer playwright, mais lento e instavel)
# Padrao: false, porque playwright nao funciona em hosts serverless.
ENABLE_FACEBOOK=false

# Modo demo: retorna fixtures em vez de fazer scraping real.
# Use pra visualizar a UI em ambientes com IP de datacenter bloqueado
# (Replit, Railway, Vercel, etc.) ou pra testar sem chave Claude.
DEMO_MODE=false
