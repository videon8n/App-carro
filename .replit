modules = ["nodejs-20"]
run = "npm install && npm start"
entrypoint = "server.js"
hidden = [".config", "package-lock.json"]

[nix]
channel = "stable-24_05"

[env]
PORT = "3000"
DEMO_MODE = "true"
ENABLE_FACEBOOK = "false"
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD = "1"

[deployment]
run = ["sh", "-c", "npm start"]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm install"]

[[ports]]
localPort = 3000
externalPort = 80
